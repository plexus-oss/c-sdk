# Plexus Flashable Firmware - ESP-IDF Configuration
# Use custom partition table with plexus_cfg NVS partition
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions.csv"
CONFIG_PARTITION_TABLE_FILENAME="partitions.csv"

# WiFi
CONFIG_ESP_WIFI_SSID=""
CONFIG_ESP_WIFI_PASSWORD=""

# NVS
CONFIG_NVS_ENCRYPTION=n

# SNTP for time sync
CONFIG_LWIP_SNTP_MAX_SERVERS=1

# HTTP client (for Plexus SDK)
CONFIG_ESP_HTTP_CLIENT_ENABLE_HTTPS=y

# TLS (required for HTTPS to Plexus)
CONFIG_ESP_TLS_USING_MBEDTLS=y
CONFIG_MBEDTLS_CERTIFICATE_BUNDLE=y
CONFIG_MBEDTLS_CERTIFICATE_BUNDLE_DEFAULT_FULL=y

# Stack sizes
CONFIG_ESP_MAIN_TASK_STACK_SIZE=8192
CONFIG_ESP_SYSTEM_EVENT_TASK_STACK_SIZE=4096

# Optimization
CONFIG_COMPILER_OPTIMIZATION_SIZE=y

# Plexus SDK options
CONFIG_PLEXUS_ENABLE_PERSISTENT_BUFFER=y
